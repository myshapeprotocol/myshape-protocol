/** SDK configuration */
interface MyShapeConfig {
    /** Your MyShape API key (starts with ms_live_ or ms_test_) */
    apiKey: string;
    /** Base URL for the MyShape API (default: https://api.myshape.com) */
    baseUrl?: string;
}
/** 3D keypoint in normalized coordinates */
interface Keypoint {
    x: number;
    y: number;
    z: number;
}
/** Single frame of motion data */
interface MotionFrame {
    /** Timestamp in seconds from capture start */
    t: number;
    /** 33 MediaPipe pose keypoints */
    keypoints: Keypoint[];
}
/** Motion sequence captured from camera */
interface MotionSequence {
    /** Frames per second of capture */
    fps: number;
    /** Ordered array of frames */
    frames: MotionFrame[];
}
/** Device information for enrollment */
interface DeviceInfo {
    platform: string;
    userAgent: string;
    screenWidth: number;
    screenHeight: number;
}
/** Result of a presence verification */
interface VerificationResult {
    /** Whether the verification passed */
    valid: boolean;
    /** Presence Entropy Score (0-1), measures biological motion entropy */
    pes: number;
    /** Raw similarity score (0-1) */
    similarity: number;
    /** Verification threshold used */
    threshold: number;
    /** Risk level applied */
    riskLevel: "low" | "medium" | "high";
    /** Rejection reason (if valid=false) */
    rejectionReason?: string;
    /** Factor breakdown for debugging */
    factors?: VerificationFactors;
}
/** Detailed verification factor breakdown */
interface VerificationFactors {
    kinematicScore: number;
    accelerationScore: number;
    jerkScore: number;
    jerkSpectrumScore: number;
    combinedScore: number;
}
/** Enrollment data — store this server-side */
interface Enrollment {
    /** Unique enrollment ID */
    id: string;
    /** User identifier */
    userId: string;
    /** Device used for enrollment */
    device: DeviceInfo;
    /** Encoded motion signature (opaque — do not modify) */
    signatureBlob: string;
    /** When the enrollment was created */
    createdAt: string;
    /** Number of samples used to create this enrollment */
    sampleCount: number;
}
/** Challenge issued by the protocol */
interface Challenge {
    /** Session key (hex-encoded) */
    sessionKey: string;
    /** Challenge data as JSON string */
    data: string;
    /** When the challenge expires */
    expiresAt: string;
}
/** Server-side validation request */
interface ValidateRequest {
    /** Enrollment ID to verify against */
    enrollmentId: string;
    /** Proof generated by verifyPresence() */
    proof: string;
    /** Challenge used during verification */
    challenge: string;
}
/** Server-side validation response */
interface ValidateResponse {
    valid: boolean;
    pes: number;
    similarity: number;
    threshold: number;
}

declare class MyShapeClient {
    readonly apiKey: string;
    readonly baseUrl: string;
    constructor(config: MyShapeConfig);
    /**
     * Verify human presence using motion capture.
     *
     * This is the main entry point. It:
     * 1. Generates a cryptographic challenge
     * 2. Captures user motion via camera (you provide the MotionSequence)
     * 3. Extracts a motion signature via WASM
     * 4. Verifies the signature against the challenge
     *
     * @param motion - MotionSequence captured from the camera
     * @param riskLevel - "low" (10% FAR), "medium" (5% FAR), or "high" (1% FAR)
     * @returns VerificationResult
     *
     * @example
     * ```typescript
     * const client = new MyShapeClient({ apiKey: 'ms_live_...' });
     * const motion = await captureMotion(camera); // your camera code
     * const result = await client.verifyPresence(motion, 'medium');
     * console.log(result.valid ? 'Human ✓' : `Rejected: ${result.rejectionReason}`);
     * ```
